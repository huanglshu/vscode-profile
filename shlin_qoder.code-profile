s\\\": true,\\r\\n    \\\"java.debug.settings.showHex\\\": false,\\r\\n    \\\"java.debug.settings.showLogicalStructure\\\": true,\\r\\n    \\\"[json]\\\": {\\r\\n        \\\"editor.defaultFormatter\\\": \\\"vscode.json-language-features\\\"\\r\\n    },\\r\\n    \\\"github.copilot.nextEditSuggestions.fixes\\\": false,\\r\\n    \\\"github.copilot.nextEditSuggestions.extendedRange\\\": false,\\r\\n    \\\"github.copilot.nextEditSuggestions.allowWhitespaceOnlyChanges\\\": false,\\r\\n    \\\"editor.inlineSuggest.edits.showLongDistanceHint\\\": false,\\r\\n    \\\"[jsonc]\\\": {\\r\\n        \\\"editor.defaultFormatter\\\": \\\"vscode.json-language-features\\\"\\r\\n    },\\r\\n    \\\"trae.chatLanguage\\\": \\\"cn\\\",\\r\\n    \\\"extensions.experimental.affinity\\\": {\\r\\n        \\\"vscode.vim\\\": 1,\\r\\n        \\\"asvetliakov.vscode-neovim\\\": 1\\r\\n    },\\r\\n    \\\"errorLens.enabledDiagnosticLevels\\\": [\\r\\n        \\\"error\\\",\\r\\n    ],\\r\\n    \\\"[java]\\\": {\\r\\n        \\\"editor.defaultFormatter\\\": \\\"redhat.java\\\"\\r\\n    },\\r\\n    \\\"workbench.editor.enablePreview\\\": false,\\r\\n    \\\"git.decorations.enabled\\\": true,\\r\\n    \\\"explorer.decorations.colors\\\": true,\\r\\n    \\\"explorer.decorations.badges\\\": true,\\r\\n    \\\"github.copilot.enable\\\": {\\r\\n        \\\"*\\\": true,\\r\\n        \\\"plaintext\\\": false,\\r\\n        \\\"markdown\\\": false,\\r\\n        \\\"scminput\\\": false,\\r\\n        \\\"java\\\": true,\\r\\n        \\\"jsonc\\\": true\\r\\n    },\\r\\n    \\\"github.copilot.chat.localeOverride\\\": \\\"zh-CN\\\",\\r\\n    \\\"chatgpt.localeOverride\\\": \\\"zh-CN\\\",\\r\\n    \\\"workbench.editor.useModal\\\": \\\"off\\\",\\r\\n    \\\"editor.formatOnSave\\\": false,\\r\\n    \\\"git.enableSmartCommit\\\": true,\\r\\n    \\\"chat.agent.maxRequests\\\": 10000,\\r\\n    \\\"chat.mcp.autostart\\\": \\\"never\\\",\\r\\n    \\\"chat.tips.enabled\\\": false,\\r\\n    \\\"workbench.startupEditor