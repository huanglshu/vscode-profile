{"name":"shlin_vscode","settings":"{\"settings\":\"{\\r\\n    \\\"gitlens.ai.model\\\": \\\"vscode\\\",\\r\\n    \\\"gitlens.ai.vscode.model\\\": \\\"copilot:gpt-4.1\\\",\\r\\n    \\\"java.errors.incompleteClasspath.severity\\\": \\\"ignore\\\", // 忽略类路径不完整警告\\r\\n    \\\"java.compile.nullAnalysis.mode\\\": \\\"automatic\\\",\\r\\n    \\\"java.debug.settings.onBuildFailureProceed\\\": true,\\r\\n    \\\"java.debug.settings.vmArgs\\\": \\\"-Dspring.output.ansi.enabled=ALWAYS -Dfile.encoding=UTF-8\\\",\\r\\n    \\\"java.configuration.maven.userSettings\\\": \\\"E:/Java/maven/maven-setting/alphax-test-settings.xml\\\",\\r\\n    \\\"java.configuration.maven.globalSettings\\\": \\\"E:/Java/maven/maven-setting/alphax-test-settings.xml\\\",\\r\\n    // \\\"java.format.settings.url\\\": \\\"https://raw.githubusercontent.com/google/styleguide/gh-pages/eclipse-java-google-style.xml\\\",\\r\\n    \\\"java.format.settings.url\\\": \\\"file:/E:/eclipse-java-google-style.xml\\\",\\r\\n    \\\"java.format.settings.profile\\\": \\\"GoogleStyle\\\",\\r\\n    \\\"java.format.enabled\\\": true,\\r\\n    \\\"problems.visibility\\\": true, \\r\\n    \\\"problems.sortOrder\\\": \\\"severity\\\",\\r\\n    \\\"problems.decorations.enabled\\\": false, // 关闭 Explorer 中的问题装饰，避免覆盖 gitDecoration 颜色\\r\\n\\r\\n    // -------------------------------\\r\\n    // 编辑器视觉优化\\r\\n    // -------------------------------\\r\\n    \\\"workbench.colorCustomizations\\\": {\\r\\n        \\\"editorWarning.foreground\\\": \\\"#00000000\\\", // 黄色波浪线透明\\r\\n        \\\"editorError.foreground\\\": \\\"#FF0000FF\\\", // 红色波浪线颜色\\r\\n        \\\"list.warningForeground\\\": \\\"#D4D4D4\\\", // 接近默认文本色，避免黄色又保持可读\\r\\n        \\\"list.errorForeground\\\": \\\"#FF0000\\\", // Explorer 红色文件图标颜色\\r\\n        \\\"peekViewEditor.background\\\": \\\"#082a3d44\\\", // 整个 References 弹窗背景\\r\\n        \\\"peekViewResult.background\\\": \\\"#082a3d44\\\", // 结果列表背景\\r\\n        \\\"peekViewResult.selectionBackground\\\": \\\"#004b7244\\\", // 选中的 item 背景\\r\\n        \\\"peekViewEditor.matchHighlightBackground\\\": \\\"#f0ecc188\\\", // 代码高亮背景（上半部）\\r\\n        \\\"peekView.border\\\": \\\"#0a9fe4DD\\\", // References 弹窗边框\\r\\n        \\\"peekViewResult.matchHighlightBackground\\\": \\\"#ffea0044\\\", // 列表高亮背景\\r\\n        \\\"editor.lineHighlightBackground\\\": \\\"#64757a66\\\", // 当前行背景色\\r\\n        \\\"editor.background\\\": \\\"#181818\\\", // 编辑器背景色\\r\\n        \\\"sideBar.background\\\": \\\"#181818\\\", // 侧边栏背景\\r\\n        \\\"activityBar.background\\\": \\\"#181818\\\", // 活动栏背景\\r\\n        \\\"tab.activeBackground\\\": \\\"#4893d133\\\", // 当前选中 Tab 背景\\r\\n        \\\"tab.activeForeground\\\": \\\"#FFFFFF\\\", // 当前选中 Tab 字体颜色\\r\\n        \\\"panel.border\\\": \\\"#0a9fe4DD\\\", //底部面板边框（终端/输出）\\r\\n        \\\"sideBar.border\\\": \\\"#0a9fe4DD\\\", // 侧边栏与编辑器之间的分割线\\r\\n        \\\"sideBarSectionHeader.border\\\": \\\"#0a9fe4DD\\\", // Explorer 内部各分组标题边框\\r\\n        \\\"list.activeSelectionBackground\\\": \\\"#0f84e433\\\", // 侧边栏选中项背景色\\r\\n        \\\"panelTitle.activeForeground\\\": \\\"#c1f505\\\", // 底部面板标题颜色\\r\\n        \\\"menu.separatorBackground\\\": \\\"#FFFFFF33\\\", // 菜单分割线颜色\\r\\n        \\\"activityBar.border\\\": \\\"#0a9fe4DD\\\", //功能栏与侧边栏的分隔线\\r\\n        \\\"activityBar.activeBackground\\\": \\\"#369cf033\\\", // 功能栏选中图标背景\\r\\n        \\\"titleBar.border\\\": \\\"#0a9fe4DD\\\", // 顶部边框（标题栏底部分割线）\\r\\n        \\\"gitDecoration.addedResourceForeground\\\": \\\"#379113\\\",\\r\\n        \\\"gitDecoration.conflictingResourceForeground\\\": \\\"#cd974b\\\",\\r\\n        \\\"gitDecoration.deletedResourceForeground\\\": \\\"#f05050\\\",\\r\\n        \\\"gitDecoration.ignoredResourceForeground\\\": \\\"#9f9f9f\\\",\\r\\n        \\\"gitDecoration.modifiedResourceForeground\\\": \\\"#5fccf7b7\\\",\\r\\n        \\\"gitDecoration.submoduleResourceForeground\\\": \\\"#7a3e9d\\\",\\r\\n        \\\"gitDecoration.untrackedResourceForeground\\\": \\\"#379113\\\",